{
  "expo": {
    "name": "Purrbo",
    "slug": "purrbo",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "scheme": "purrbo",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#FF4D8D",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.purrbo.app",
      "appleTeamId": "D454K5853W",
      "entitlements": {
        "com.apple.security.application-groups": ["group.com.purrbo.app"]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["com.purrbo.app"]
          }
        ]
      }
    },
    "android": {
      "package": "com.purrbo.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF4D8D"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "category": ["DEFAULT", "BROWSABLE"],
          "data": [{ "scheme": "com.purrbo.app" }]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-audio",
      "expo-asset",
      "expo-font",
      "expo-status-bar",
      "@bacons/apple-targets",
      [
        "expo-alternate-app-icons",
        [
          {
            "name": "Mun",
            "ios": "./assets/persona-icons/icon-mun.png",
            "android": { "foregroundImage": "./assets/persona-icons/icon-mun-android.png", "backgroundColor": "#6C63E0" }
          },
          {
            "name": "Cam",
            "ios": "./assets/persona-icons/icon-cam.png",
            "android": { "foregroundImage": "./assets/persona-icons/icon-cam-android.png", "backgroundColor": "#FF9E4D" }
          },
          {
            "name": "Ly",
            "ios": "./assets/persona-icons/icon-ly.png",
            "android": { "foregroundImage": "./assets/persona-icons/icon-ly-android.png", "backgroundColor": "#E8743B" }
          },
          {
            "name": "Sep",
            "ios": "./assets/persona-icons/icon-sep.png",
            "android": { "foregroundImage": "./assets/persona-icons/icon-sep-android.png", "backgroundColor": "#8B7BB0" }
          },
          {
            "name": "Bong",
            "ios": "./assets/persona-icons/icon-bong.png",
            "android": { "foregroundImage": "./assets/persona-icons/icon-bong-android.png", "backgroundColor": "#EC6FA0" }
          },
          {
            "name": "Xu",
            "ios": "./assets/persona-icons/icon-xu.png",
            "android": { "foregroundImage": "./assets/persona-icons/icon-xu-android.png", "backgroundColor": "#22B584" }
          },
          {
            "name": "Bo",
            "ios": "./assets/persona-icons/icon-bo.png",
            "android": { "foregroundImage": "./assets/persona-icons/icon-bo-android.png", "backgroundColor": "#7FB77E" }
          },
          {
            "name": "Sin",
            "ios": "./assets/persona-icons/icon-sin.png",
            "android": { "foregroundImage": "./assets/persona-icons/icon-sin-android.png", "backgroundColor": "#D99A22" }
          }
        ]
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "110f26da-d53d-4329-a603-906643f324e0"
      }
    }
  }
}
