# ── Purrbo App (Expo) · ENV mẫu ────────────────────────────────────
# Copy sang .env ở gốc:  cp .env.example .env
# Dev (Expo Go): trỏ IP LAN của máy chạy backend
EXPO_PUBLIC_API_URL=http://192.168.1.215:8000
# AD-13 · Kết nối Google Calendar (Cài đặt → Google Calendar). Cần OAuth client
# (Google Cloud). Chưa điền → nút kết nối hiện thông báo cần cấu hình.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
