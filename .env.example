# ── Purrbo App (Expo) · ENV mẫu ────────────────────────────────────
# Copy sang .env ở gốc:  cp .env.example .env
# ⚠️ Mọi biến EXPO_PUBLIC_* bị NHÚNG vào bundle app → chỉ để CLIENT ID / APP ID
#    (công khai được). TUYỆT ĐỐI không để secret (App Secret, Client Secret) ở đây.

# Dev (Expo Go): trỏ IP LAN của máy chạy backend · Prod: https://purrbo.fun
EXPO_PUBLIC_API_URL=http://192.168.1.215:8000

# ── Google (đăng nhập + đồng bộ Google Calendar) · AD-8, AD-13 ──────
# Google Cloud Console → APIs & Services → Credentials → OAuth client ID.
# Tạo đủ 3 loại (iOS bundle=com.purrbo.app · Android package=com.purrbo.app · Web)
# rồi dán ĐỦ CẢ 3 — expo-auth-session tự chọn đúng cái theo nền tảng.
# (Vẫn đọc EXPO_PUBLIC_GOOGLE_CLIENT_ID cũ như fallback cho web nếu muốn.)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxx-ios.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxxx-android.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxx-web.apps.googleusercontent.com

# ── Lark / Feishu (đồng bộ Lark Calendar) · AD-13 ──────────────────
# Lark Developer Console → Credentials & Basic Info → App ID.
EXPO_PUBLIC_LARK_APP_ID=cli_xxxxxxxxxxxx
