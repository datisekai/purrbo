# ── Purrbo Backend · ENV mẫu ───────────────────────────────────────
# Copy sang api/.env rồi điền giá trị thật:  cp api/.env.example api/.env
OPENAI_API_KEY=sk-...
DIALOGUE_PROVIDER=openai
NLP_PROVIDER=openai
# PostgreSQL (dev + prod đều Postgres, không dùng SQLite).
# Docker (dev/prod) tự ép DATABASE_URL qua compose → không cần chỉnh dòng này.
# Chạy tay api/run.sh: bật `docker compose up -d db` rồi giữ localhost bên dưới.
DATABASE_URL=postgresql+asyncpg://purrbo:purrbo@localhost:5432/purrbo
# Cổng publish của container (nginx VPS proxy vào 127.0.0.1:APP_PORT)
APP_PORT=3012
JWT_SECRET=changeme
# Prod: giới hạn origin cho web (landing/admin cùng domain). App native không cần CORS.
CORS_ORIGINS=https://purrbo.fun,https://www.purrbo.fun
# AD-13 · Google Calendar: google = kéo lịch thật (app tự OAuth, truyền access_token
# qua ?gtoken=); mock = trả event mẫu để demo. Không token → adapter google trả [].
CALENDAR_PROVIDER=google
# Lark quốc tế = larksuite (mặc định); Feishu Trung Quốc = https://open.feishu.cn
LARK_BASE=https://open.larksuite.com
# AD-8 · Verify aud của Google id_token. aud = client id của NỀN TẢNG đăng nhập
# (iOS/Android/Web khác nhau) → dán ĐỦ CẢ 3, phẩy ngăn cách, không khoảng trắng.
# Trống = tắt kiểm tra aud (chỉ nên để trống khi dev).
GOOGLE_CLIENT_IDS=xxxx-web.apps.googleusercontent.com,xxxx-ios.apps.googleusercontent.com,xxxx-android.apps.googleusercontent.com
# Đăng nhập web admin (/admin) — ĐỔI trước khi lên prod
ADMIN_USERNAME=admin
ADMIN_PASSWORD=doi-mat-khau-nay
# (legacy) header X-Admin-Token cho script/CI — tuỳ chọn
ADMIN_TOKEN=doi-token-nay
